# Environment Configuration for Cybersecurity Dashboard

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@db:5432/cybersecurity_db
REDIS_URL=redis://redis:6379/0

# AWS Configuration
AWS_REGION=us-east-1
# Used by boto3 in backend (Bedrock, Polly); defaults to AWS_REGION in docker-compose if unset
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Amazon Bedrock (LLM + voice intent fallback) — required in Docker for live Claude; omit for mock-only
# BEDROCK_API_KEY=your-bedrock-api-key
# BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5

# SMTP Configuration (local test defaults)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@local.test

# Grafana Configuration
GRAFANA_URL=http://grafana:3000
GRAFANA_USERNAME=admin
GRAFANA_PASSWORD=admin

# Prometheus Configuration
PROMETHEUS_URL=http://prometheus:9090

# Security Configuration
# HS256 for CSV export /api/findings/export/csv: backend reads JWT_SECRET first, then JWT_SECRET_KEY.
# JWT_SECRET=your-jwt-secret
# JWT_SECRET_KEY=your-jwt-secret-key
# Without either secret: FLASK_ENV=development or ALLOW_INSECURE_JWT=true bypasses JWT (local only).
JWT_SECRET_KEY=your-jwt-secret-key
ENCRYPTION_KEY=your-encryption-key

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Monitoring Configuration
ENABLE_METRICS=true
METRICS_PORT=9090